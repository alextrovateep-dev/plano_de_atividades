rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        || exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && hasProfile() && userData().role == 'superadmin';
    }

    function userEmpresaId() {
      return userData().empresaId;
    }

    function canReadEmpresa(empresaId) {
      return isSignedIn() && hasProfile()
        && (isSuperAdmin() || userEmpresaId() == empresaId);
    }

    function canEditEmpresa(empresaId) {
      return isSignedIn() && hasProfile()
        && (isSuperAdmin() || (userData().role == 'admin' && userEmpresaId() == empresaId));
    }

    // Perfil: coleção principal "usuarios" (+ legado "users")
    match /usuarios/{userId} {
      allow read: if isSignedIn() && hasProfile()
        && (request.auth.uid == userId || isSuperAdmin());
      allow create, update, delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && hasProfile()
        && (request.auth.uid == userId || isSuperAdmin());
      allow create, update, delete: if isSuperAdmin();
    }

    match /empresas/{empresaId} {
      allow read: if canReadEmpresa(empresaId);
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || canEditEmpresa(empresaId);

      match /profissionais/{docId} {
        allow read: if canReadEmpresa(empresaId);
        allow create, update, delete: if canEditEmpresa(empresaId);
      }

      match /escopo/{docId} {
        allow read: if canReadEmpresa(empresaId);
        allow create, update, delete: if canEditEmpresa(empresaId);
      }

      match /tarefas/{docId} {
        allow read: if canReadEmpresa(empresaId);
        allow create, update, delete: if canEditEmpresa(empresaId);
      }
    }

    // Estatística do painel: collectionGroup("tarefas")
    match /{path=**}/tarefas/{docId} {
      allow read: if isSuperAdmin();
    }
  }
}
