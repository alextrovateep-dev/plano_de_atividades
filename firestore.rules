rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        || exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && hasProfile() && userData().role == 'superadmin';
    }

    function isTeepStaff() {
      return isSignedIn() && hasProfile()
        && (userData().role == 'superadmin' || userData().role == 'teep_admin');
    }

    function userEmpresaId() {
      return userData().empresaId;
    }

    function usuarioTemEmpresaId(empresaId) {
      return userEmpresaId() == empresaId
        || ('empresasIds' in userData() && empresaId in userData().empresasIds);
    }

    function canReadEmpresa(empresaId) {
      return isSignedIn() && hasProfile()
        && (isTeepStaff() || usuarioTemEmpresaId(empresaId));
    }

    function canEditEmpresa(empresaId) {
      return isSignedIn() && hasProfile()
        && (isTeepStaff() || (userData().role == 'admin' && userEmpresaId() == empresaId));
    }

    function targetUsuarioRole(userId) {
      return exists(/databases/$(database)/documents/usuarios/$(userId))
        ? get(/databases/$(database)/documents/usuarios/$(userId)).data.role
        : (exists(/databases/$(database)/documents/users/$(userId))
          ? get(/databases/$(database)/documents/users/$(userId)).data.role
          : '');
    }

    function canManageUsuario(userId) {
      return isTeepStaff()
        && (isSuperAdmin() || targetUsuarioRole(userId) != 'superadmin');
    }

    // Admin do cliente pode criar utilizadores de leitura (user) na própria empresa
    function canCreateUsuarioCliente() {
      return isSignedIn() && hasProfile()
        && userData().role == 'admin'
        && userEmpresaId() != null
        && request.resource.data.role == 'user'
        && request.resource.data.empresaId == userEmpresaId();
    }

    // Vincular colaborador existente a outro projeto (empresasIds)
    function canVincularColaboradorMultiProjeto(userId) {
      return isSignedIn() && hasProfile()
        && (isTeepStaff()
          || (userData().role == 'admin'
            && targetUsuarioRole(userId) == 'user'
            && userEmpresaId() in request.resource.data.get('empresasIds', [])));
    }

    function isSelfPasswordDoneUpdate(userId) {
      return request.auth.uid == userId
        && resource.data.mustChangePassword == true
        && request.resource.data.mustChangePassword == false
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
        && request.resource.data.empresaId == resource.data.empresaId;
    }

    match /usuarios/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || isTeepStaff()
        || (hasProfile() && userData().role == 'admin')
      );
      allow create: if (isTeepStaff()
        && (request.resource.data.role != 'superadmin' || isSuperAdmin()))
        || canCreateUsuarioCliente();
      allow update: if canManageUsuario(userId)
        || isSelfPasswordDoneUpdate(userId)
        || canVincularColaboradorMultiProjeto(userId);
      allow delete: if canManageUsuario(userId);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || isTeepStaff()
      );
      allow delete: if isTeepStaff();
      allow create, update: if isTeepStaff();
    }

    match /_config/{docId} {
      allow read, write: if isTeepStaff();
    }

    match /empresas/{empresaId} {
      allow read: if canReadEmpresa(empresaId);
      allow create, delete: if isTeepStaff();
      allow update: if isTeepStaff() || canEditEmpresa(empresaId);

      match /profissionais/{docId} {
        allow read: if canReadEmpresa(empresaId)
          || (isSignedIn() && hasProfile() && resource.data.uid == request.auth.uid);
        allow create, update, delete: if canEditEmpresa(empresaId);
      }

      match /escopo/{docId} {
        allow read: if canReadEmpresa(empresaId);
        allow create, update, delete: if canEditEmpresa(empresaId);
      }

      match /tarefas/{docId} {
        allow read: if canReadEmpresa(empresaId);
        allow create, update, delete: if canEditEmpresa(empresaId);
      }
    }

    match /{path=**}/tarefas/{docId} {
      allow read: if isTeepStaff();
    }

    match /audit_logs/{logId} {
      allow create: if isSignedIn() && hasProfile();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }
  }
}
